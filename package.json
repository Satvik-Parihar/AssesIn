{
  "name": "online-exam-system",
  "private": true,
  "scripts": {
    "start-all": "node scripts/start-all.js",
    "start:backend": "dotnet run --project backend/OnlineExamAPI/OnlineExamAPI.csproj --urls http://localhost:5000",
    "start:frontend": "npm --prefix frontend/online-exam start",
    "test:backend": "dotnet test backend/OnlineExamAPI.Tests/OnlineExamAPI.Tests.csproj --verbosity normal",
    "test:frontend": "cd frontend/online-exam && npx ng test --watch=false --browsers=ChromeHeadless",
    "install:frontend": "cd frontend/online-exam && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
